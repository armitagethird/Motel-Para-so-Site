---
import { motel, whatsappLink } from "~/data/motel";
---

<section
  id="top"
  class="relative isolate min-h-[100dvh] flex items-center overflow-hidden"
  aria-labelledby="hero-title"
>
  <!-- Background: pre-blurred poster (cheap), with the live video layered
       on top only on larger screens where the GPU can keep up. -->
  <div class="absolute inset-0 -z-10 bg-cinema">
    <div class="hero-bg absolute inset-0"></div>
    <video
      class="hero-video absolute inset-0 size-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/media/hero-poster.webp"
      aria-hidden="true"
      tabindex="-1"
      disablepictureinpicture
      disableremoteplayback
      data-hero-video
    >
      <source src="/media/hero.webm" type="video/webm" />
      <source src="/media/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-cinema/55"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-cinema via-cinema/30 to-cinema/55"></div>
  </div>

  <div class="container-page relative w-full pt-[calc(var(--header-height)+1rem)] pb-32 md:pb-36">
    <div class="flex flex-col items-center text-center gap-8 md:gap-10 max-w-2xl mx-auto">
      <picture class="reveal">
        <source type="image/webp" srcset="/media/logo-320.webp 1x, /media/logo-640.webp 2x" />
        <img
          src="/media/logo.png"
          alt={`Logo ${motel.name}`}
          width="240"
          height="240"
          class="block w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 object-contain hero-logo-shadow"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>

      <div class="flex flex-col items-center gap-4 reveal" style="transition-delay: 60ms">
        <span class="eyebrow text-paper/80">Motel em São Luís — Maranhão</span>
        <h1 id="hero-title" class="display-xl text-paper text-balance">
          Seu paraíso
          <span class="font-script text-apple normal-case lowercase block leading-[0.85] -mt-1 md:-mt-2">particular</span>
        </h1>
        <p class="text-paper/85 text-base md:text-lg max-w-md text-pretty leading-relaxed">
          O Paraíso Motel é um motel em São Luís — MA com 16 suítes 24h, hidromassagem e privacidade total.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 reveal" style="transition-delay: 120ms">
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener"
          class="btn btn-primary text-base px-7 py-4"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Reservar pelo WhatsApp
        </a>
        <a href="#suites" class="btn btn-ghost text-base px-7 py-4">
          Ver suítes
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <a
      href="#sobre"
      class="absolute left-1/2 -translate-x-1/2 bottom-8 md:bottom-10 flex flex-col items-center gap-2 text-paper/55 hover:text-paper transition-colors"
      aria-label="Rolar para a próxima seção"
    >
      <span class="text-[10px] uppercase tracking-[0.32em]">Descer</span>
      <svg width="20" height="22" viewBox="0 0 20 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="hero-arrow" aria-hidden="true">
        <line x1="10" y1="2" x2="10" y2="18"/>
        <polyline points="3 12 10 19 17 12"/>
      </svg>
    </a>
  </div>
</section>

<style>
  /* Mobile-first: cheap pre-blurred image as background, no live video. */
  .hero-bg {
    background-image: url("/media/hero-poster-blur.webp");
    background-size: cover;
    background-position: center;
  }
  .hero-video { display: none; }

  /* Cheaper shadow than `drop-shadow-[0_18px_40px_rgba(0,0,0,0.55)]` —
     a tinted radial fade behind the logo, painted once. */
  .hero-logo-shadow {
    filter: drop-shadow(0 8px 14px rgba(0, 0, 0, 0.45));
  }

  /* Bouncing arrow only animates on devices with a mouse; saves a constant
     animation cycle on phones. */
  @media (hover: hover) and (pointer: fine) {
    .hero-arrow {
      animation: bounce-down 1.8s ease-in-out infinite;
    }
  }

  /* Desktop: live video on top of the blurred bg, with its own blur and a
     subtle overscale to hide blur edges. GPU on desktop handles per-frame
     blur fine — the cinematic look is preserved. */
  @media (min-width: 1024px) {
    .hero-video {
      display: block;
      filter: blur(14px) saturate(115%) brightness(0.85);
      transform: scale(1.06);
      transform-origin: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video { display: none !important; }
  }
</style>

<script>
  const video = document.querySelector<HTMLVideoElement>("[data-hero-video]");
  if (video) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const desktop = window.matchMedia("(min-width: 1024px)").matches;
    if (reduce || !desktop) {
      // Keep the DOM but never load the source on mobile/reduced-motion.
      video.removeAttribute("autoplay");
      video.pause();
      video.removeAttribute("preload");
    } else if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) video.play().catch(() => {});
            else video.pause();
          }
        },
        { threshold: 0.1 }
      );
      io.observe(video);
    }
  }
</script>
