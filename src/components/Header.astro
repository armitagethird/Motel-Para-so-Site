---
import { motel, whatsappLink } from "~/data/motel";

const links = [
  { href: "#suites", label: "Suítes" },
  { href: "#precos", label: "Preços" },
  { href: "#cardapio", label: "Cardápio" },
  { href: "#localizacao", label: "Localização" },
  { href: "#contato", label: "Contato" },
];
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-40 transition-[background-color,backdrop-filter,box-shadow] duration-300"
  data-header
>
  <div class="container-page flex items-center justify-between gap-6 py-4 md:py-5">
    <a href="#top" aria-label={`${motel.name} — voltar ao topo`} class="flex items-center gap-3 group">
      <picture>
        <source type="image/webp" srcset="/media/logo-320.webp" />
        <img
          src="/media/logo.png"
          alt={`${motel.name} logo`}
          width="56"
          height="56"
          class="size-10 md:size-12 rounded-full ring-1 ring-white/10 transition-transform group-hover:rotate-[-4deg]"
          loading="eager"
          decoding="async"
        />
      </picture>
      <span class="hidden sm:flex flex-col leading-none">
        <span class="font-display text-xl tracking-wider text-paper">PARAÍSO</span>
        <span class="font-script text-apple text-base -mt-1">Motel</span>
      </span>
    </a>

    <nav aria-label="Principal" class="hidden lg:block">
      <ul class="flex items-center gap-1 text-sm font-medium">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="px-3 py-2 rounded-full text-paper/80 hover:text-paper hover:bg-paper/5 transition-colors"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener"
        class="btn btn-whatsapp text-sm px-4 py-2.5"
        aria-label="Falar com o motel pelo WhatsApp"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        <span class="hidden sm:inline">Reservar</span>
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center size-10 rounded-full text-paper hover:bg-paper/10 transition-colors"
        aria-label="Abrir menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    class="lg:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out border-t border-white/5"
    data-menu-panel
  >
    <nav aria-label="Menu mobile" class="container-page py-3">
      <ul class="flex flex-col">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="block px-2 py-3 text-base text-paper/85 hover:text-paper border-b border-white/5"
              data-menu-link
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-header]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-menu-link]");

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 24) header.classList.add("scrolled");
      else header.classList.remove("scrolled");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  const setOpen = (open: boolean) => {
    if (!panel || !toggle) return;
    toggle.setAttribute("aria-expanded", String(open));
    panel.style.maxHeight = open ? `${panel.scrollHeight}px` : "0px";
  };
  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!isOpen);
  });
  links.forEach((l) => l.addEventListener("click", () => setOpen(false)));
</script>

<style>
  header {
    background: transparent;
  }
  header.scrolled {
    background: color-mix(in srgb, var(--color-cinema) 78%, transparent);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    box-shadow: 0 1px 0 0 rgba(255, 255, 255, 0.04);
  }
</style>
