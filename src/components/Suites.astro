---
import { motel } from "~/data/motel";
import SuiteCard from "./SuiteCard.astro";
import SuiteModal from "./SuiteModal.astro";
---

<section id="suites" class="section-pad bg-cinema-soft relative">
  <div class="container-page">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 reveal">
      <div class="max-w-2xl">
        <span class="eyebrow">As Suítes</span>
        <h2 class="display-lg mt-6 text-paper">
          Três categorias.
          <span class="font-script text-apple block normal-case mt-1">Um único cuidado.</span>
        </h2>
      </div>
      <p class="text-paper/70 max-w-md text-pretty leading-relaxed">
        São <strong class="text-paper">16 suítes</strong> distribuídas em três categorias. Toque em um card para ver fotos e detalhes.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {motel.suites.map((suite, i) => <SuiteCard suite={suite} index={i} />)}
    </div>

    <p class="mt-10 text-center text-sm text-paper/55 reveal">
      As fotos serão substituídas pelas imagens reais das suítes em breve.
    </p>
  </div>

  <!-- Modals (one per suite) — rendered outside the cards container so the
       <dialog> element gets full-screen overlay positioning via the top layer. -->
  {motel.suites.map((suite) => <SuiteModal suite={suite} />)}
</section>

<script>
  // Open: any element with [data-suite-trigger] (click + Enter/Space).
  // Close: any [data-modal-close] inside the dialog, ESC (native), or
  //        backdrop click (mousedown outside the dialog content panel).
  const triggers = document.querySelectorAll<HTMLElement>("[data-suite-trigger]");
  const dialogs = document.querySelectorAll<HTMLDialogElement>("[data-suite-modal]");

  const openModal = (id: string) => {
    const dialog = document.getElementById(id);
    if (dialog instanceof HTMLDialogElement) {
      dialog.showModal();
      document.body.style.overflow = "hidden";
    }
  };

  const closeModal = (dialog: HTMLDialogElement) => {
    dialog.close();
    document.body.style.overflow = "";
  };

  triggers.forEach((el) => {
    const targetId = el.getAttribute("data-modal-target");
    if (!targetId) return;
    el.addEventListener("click", () => openModal(targetId));
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(targetId);
      }
    });
  });

  dialogs.forEach((dialog) => {
    // Restore body scroll when the dialog closes (native close, ESC, etc).
    dialog.addEventListener("close", () => {
      document.body.style.overflow = "";
    });
    // Explicit close buttons
    dialog.querySelectorAll<HTMLElement>("[data-modal-close]").forEach((btn) => {
      btn.addEventListener("click", () => closeModal(dialog));
    });
    // Backdrop click — clicking the dialog itself (the rect outside the
    // content panel) closes the modal. We track mousedown to avoid
    // accidental closes on text-selection drags that finish outside.
    dialog.addEventListener("mousedown", (e) => {
      if (e.target === dialog) closeModal(dialog);
    });
  });
</script>
