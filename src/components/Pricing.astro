---
import { motel, formatBRL } from "~/data/motel";
---

<section id="precos" class="section-pad bg-cinema relative lazy-section">
  <div class="container-page">
    <div class="text-center max-w-2xl mx-auto reveal">
      <span class="eyebrow">Preços</span>
      <h2 class="display-lg mt-6 text-paper">
        Tabela clara,
        <span class="font-script text-apple block normal-case mt-1">sem surpresas.</span>
      </h2>
      <p class="mt-5 text-paper/75 text-pretty leading-relaxed">
        Compare as três categorias e escolha a que combina com o seu momento.
      </p>
    </div>

    <!-- Comparison table -->
    <div class="mt-12 max-w-4xl mx-auto reveal">
      <div class="card overflow-hidden">
        <table class="w-full text-left">
          <caption class="sr-only">Tabela de preços por categoria de suíte</caption>
          <thead>
            <tr class="border-b border-paper/10 bg-paper/[0.03]">
              <th scope="col" class="px-4 md:px-6 py-4 text-xs uppercase tracking-[0.22em] text-paper/55 font-medium">Categoria</th>
              <th scope="col" class="px-4 md:px-6 py-4 text-xs uppercase tracking-[0.22em] text-paper/55 font-medium text-right">Estadia 2h</th>
              <th scope="col" class="px-4 md:px-6 py-4 text-xs uppercase tracking-[0.22em] text-paper/55 font-medium text-right">Pernoite 00h–06h</th>
            </tr>
          </thead>
          <tbody>
            {motel.suites.map((s) => (
              <tr class="border-b border-paper/5 last:border-0">
                <th scope="row" class="px-4 md:px-6 py-5 align-middle">
                  <div class="font-display text-xl md:text-2xl text-paper tracking-wide">{s.name}</div>
                  <div class="text-xs text-paper/55 mt-1">{s.units} unidades</div>
                </th>
                <td class="px-4 md:px-6 py-5 text-right font-display text-2xl md:text-3xl text-paper">{formatBRL(s.price2h)}</td>
                <td class="px-4 md:px-6 py-5 text-right font-display text-2xl md:text-3xl text-gold">{formatBRL(s.priceOvernight)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Rules -->
    <div class="mt-8 max-w-4xl mx-auto reveal" style="transition-delay: 100ms">
      <div class="card p-6 md:p-7 border-l-4 border-l-apple flex flex-col sm:flex-row gap-5">
        <div class="size-12 rounded-2xl bg-apple/15 ring-1 ring-apple/30 grid place-items-center text-apple shrink-0">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
          </svg>
        </div>
        <div>
          <h3 class="font-display text-2xl text-paper tracking-wide">Bom saber</h3>
          <ul class="mt-3 space-y-2 text-paper/80 text-sm md:text-base leading-relaxed">
            {motel.rules.map((r) => (
              <li class="flex gap-2.5">
                <span class="text-gold mt-1">•</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
