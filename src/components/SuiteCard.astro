---
import type { Suite } from "~/data/motel";
import { formatBRL } from "~/data/motel";

interface Props {
  suite: Suite;
  index: number;
}
const { suite, index } = Astro.props;

// Placeholder hue per suite — picture mosaic with an apple SVG glyph on top.
// data-replaceable="true" tells maintainers these elements should be swapped
// for real photos when the owner provides them.
const hue = suite.placeholderHue;
---

<article
  class="card relative overflow-hidden group flex flex-col reveal"
  style={`transition-delay: ${index * 90}ms`}
  data-suite={suite.id}
>
  <!-- Placeholder image (replace with real photo later) -->
  <div
    class="relative aspect-[4/3] overflow-hidden"
    data-replaceable="true"
    data-replace-hint={`Trocar por foto real da ${suite.name}`}
  >
    <div
      class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
      style={`background:
        radial-gradient(circle at 30% 20%, hsl(${hue} 60% 50% / 0.55), transparent 55%),
        radial-gradient(circle at 80% 80%, hsl(${(hue + 30) % 360} 70% 35% / 0.65), transparent 60%),
        linear-gradient(160deg, #1a1410, #2a1f17 60%, #14110e);`}
    ></div>
    <!-- Apple icon (matches the logo) -->
    <svg
      viewBox="0 0 64 64"
      class="absolute inset-0 m-auto size-20 text-apple drop-shadow-[0_8px_24px_rgba(200,16,46,0.4)] opacity-90"
      aria-hidden="true"
    >
      <path
        fill="currentColor"
        d="M40 18c-2.5 0-5 1.4-6.5 3.6C32 19.4 29.5 18 27 18c-6 0-11 5.5-11 13 0 8 6 19 11 19 2.5 0 4.5-1.5 6.5-1.5S38 50 40.5 50c5 0 11-11 11-19 0-7.5-5-13-11.5-13Z"
      />
      <path fill="#1a8a3f" d="M35 14c0-3 2.5-5.5 5.5-5.5C40.5 11.5 38 14 35 14Z" />
    </svg>
    <div class="absolute top-3 left-3 text-[10px] uppercase tracking-[0.28em] text-paper/60 bg-cinema/70 px-2 py-1 rounded-full">
      Foto ilustrativa
    </div>
    <div class="absolute top-3 right-3 text-[10px] uppercase tracking-[0.28em] text-cinema bg-gold px-2 py-1 rounded-full font-semibold">
      {suite.tier}
    </div>
  </div>

  <div class="p-6 md:p-7 flex-1 flex flex-col gap-5">
    <header class="flex items-start justify-between gap-4">
      <div>
        <h3 class="display-md text-paper">{suite.name}</h3>
        <p class="mt-1 text-sm text-paper/60">{suite.units} unidades · {suite.rooms}</p>
      </div>
    </header>

    <ul class="flex flex-wrap gap-2 text-xs">
      {suite.features.map((f) => (
        <li class="px-2.5 py-1 rounded-full bg-paper/5 ring-1 ring-paper/10 text-paper/80">{f}</li>
      ))}
    </ul>

    <div class="mt-auto pt-4 border-t border-paper/10 grid grid-cols-2 gap-2">
      <div>
        <div class="text-[10px] uppercase tracking-[0.24em] text-paper/55">Estadia 2h</div>
        <div class="font-display text-3xl text-paper mt-0.5">{formatBRL(suite.price2h)}</div>
      </div>
      <div class="text-right">
        <div class="text-[10px] uppercase tracking-[0.24em] text-paper/55">Pernoite 00h–06h</div>
        <div class="font-display text-3xl text-gold mt-0.5">{formatBRL(suite.priceOvernight)}</div>
      </div>
    </div>
  </div>
</article>
