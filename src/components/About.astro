---
import { motel } from "~/data/motel";

const icons = {
  suites: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 26V12l12-6 12 6v14"/><path d="M11 26v-7h10v7"/><circle cx="16" cy="15" r="1.5" fill="currentColor"/></svg>`,
  clock: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="16" cy="16" r="12"/><path d="M16 9v7l4.5 3"/></svg>`,
  lock: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="7" y="14" width="18" height="14" rx="2"/><path d="M11 14V9a5 5 0 0 1 10 0v5"/><circle cx="16" cy="21" r="1.5" fill="currentColor"/></svg>`,
};
---

<section id="sobre" class="section-pad bg-cinema relative overflow-hidden">
  <div class="absolute inset-0 -z-10 opacity-[0.04]" aria-hidden="true">
    <div class="absolute -top-40 -left-20 w-[40rem] h-[40rem] rounded-full bg-gold blur-[120px]"></div>
    <div class="absolute -bottom-40 -right-20 w-[36rem] h-[36rem] rounded-full bg-apple blur-[120px]"></div>
  </div>

  <div class="container-page">
    <div class="max-w-3xl mx-auto text-center reveal">
      <span class="eyebrow">Sobre o Paraíso</span>
      <h2 class="display-lg mt-6 text-paper">
        Um clássico de São Luís,
        <span class="font-script text-apple block normal-case mt-1">com toques de hoje.</span>
      </h2>
      <p class="mt-6 text-paper/80 text-lg leading-relaxed text-pretty">
        Cuidamos dos detalhes para que você se sinta em casa — só que melhor. Da chegada discreta ao
        cardápio servido na porta, do quarto simples ao super luxo com hidromassagem, tudo foi
        pensado para um único objetivo: o seu momento.
      </p>
    </div>

    <ul class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {motel.highlights.map((h, i) => (
        <li class="card relative p-7 md:p-8 reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="flex items-start gap-4">
            <div class="size-12 rounded-2xl bg-paper/5 ring-1 ring-paper/10 grid place-items-center text-gold shrink-0" set:html={icons[h.icon as keyof typeof icons]}></div>
            <div>
              <h3 class="font-display text-2xl text-paper tracking-wide">{h.label}</h3>
              <p class="mt-1 text-sm text-paper/70 leading-relaxed">{h.detail}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  [data-icon] svg { width: 1.5rem; height: 1.5rem; }
</style>
