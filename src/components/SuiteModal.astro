---
import type { Suite } from "~/data/motel";
import { formatBRL, motel, whatsappLink } from "~/data/motel";

interface Props {
  suite: Suite;
}
const { suite } = Astro.props;

const message = `Olá! Tenho interesse na ${suite.name} do Paraíso Motel. Pode me passar disponibilidade?`;
const photos = Array.from({ length: suite.photoCount }, (_, i) => i);
---

<dialog
  class="suite-modal"
  id={`modal-${suite.id}`}
  aria-labelledby={`modal-${suite.id}-title`}
  data-suite-modal
>
  <div class="suite-modal-content card relative bg-cinema-soft border-paper/15 max-h-[100dvh] sm:max-h-[92vh] overflow-y-auto">
    <button
      type="button"
      class="absolute top-3 right-3 z-10 size-10 rounded-full bg-cinema/85 text-paper hover:bg-apple hover:text-paper transition-colors grid place-items-center"
      aria-label="Fechar"
      data-modal-close
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>

    <!-- Photo gallery (placeholders for now — replace src= when real photos arrive) -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5 p-1.5">
      {photos.map((i) => {
        const isHero = i === 0;
        const hueShift = (i * 22) % 360;
        return (
          <div
            class:list={[
              "relative overflow-hidden rounded-xl bg-cinema",
              isHero ? "col-span-2 sm:col-span-2 row-span-2 aspect-[4/3] sm:aspect-auto" : "aspect-square",
            ]}
            data-replaceable="true"
            data-replace-hint={`Trocar pela foto ${i + 1} da ${suite.name}`}
          >
            <div
              class="absolute inset-0 transition-transform duration-700 hover:scale-105"
              style={`background:
                radial-gradient(circle at ${30 + i * 10}% ${20 + i * 8}%, hsl(${(suite.placeholderHue + hueShift) % 360} 60% 50% / 0.55), transparent 55%),
                radial-gradient(circle at ${80 - i * 5}% ${70 + i * 4}%, hsl(${(suite.placeholderHue + hueShift + 30) % 360} 70% 35% / 0.6), transparent 60%),
                linear-gradient(160deg, #1a1410, #2a1f17 60%, #14110e);`}
            ></div>
            <svg
              viewBox="0 0 64 64"
              class="absolute inset-0 m-auto text-apple opacity-80 size-12 sm:size-14"
              aria-hidden="true"
            >
              <path
                fill="currentColor"
                d="M40 18c-2.5 0-5 1.4-6.5 3.6C32 19.4 29.5 18 27 18c-6 0-11 5.5-11 13 0 8 6 19 11 19 2.5 0 4.5-1.5 6.5-1.5S38 50 40.5 50c5 0 11-11 11-19 0-7.5-5-13-11.5-13Z"
              />
              <path fill="#1a8a3f" d="M35 14c0-3 2.5-5.5 5.5-5.5C40.5 11.5 38 14 35 14Z" />
            </svg>
            {isHero && (
              <div class="absolute top-3 left-3 text-[10px] uppercase tracking-[0.28em] text-paper/70 bg-cinema/70 px-2 py-1 rounded-full">
                Foto ilustrativa
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="p-6 md:p-8">
      <header class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
        <div>
          <span class="eyebrow">{suite.tier}</span>
          <h2 id={`modal-${suite.id}-title`} class="display-md text-paper mt-3">
            {suite.name}
          </h2>
          <p class="mt-1 text-sm text-paper/65">{suite.units} unidades · {suite.rooms}</p>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:gap-6 sm:text-right">
          <div>
            <div class="text-[10px] uppercase tracking-[0.24em] text-paper/55">Estadia 2h</div>
            <div class="font-display text-3xl text-paper mt-0.5">{formatBRL(suite.price2h)}</div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-[0.24em] text-paper/55">Pernoite</div>
            <div class="font-display text-3xl text-gold mt-0.5">{formatBRL(suite.priceOvernight)}</div>
          </div>
        </div>
      </header>

      <p class="text-paper/85 leading-relaxed text-pretty">{suite.description}</p>

      <div class="mt-7 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-display text-xl text-paper tracking-wide mb-3">Diferenciais</h3>
          <ul class="space-y-2">
            {suite.highlights.map((h) => (
              <li class="flex items-start gap-2.5 text-sm text-paper/85">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-gold" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-display text-xl text-paper tracking-wide mb-3">Tudo que tem</h3>
          <ul class="flex flex-wrap gap-2">
            {suite.features.map((f) => (
              <li class="px-2.5 py-1 rounded-full bg-paper/[0.06] ring-1 ring-paper/10 text-xs text-paper/85">{f}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-7 p-4 rounded-xl bg-paper/[0.04] ring-1 ring-paper/10 text-sm text-paper/75 leading-relaxed">
        <strong class="text-paper">Bom saber:</strong> Adicional de R$ 15,00 passando das 02h00. Cortesia (item de brinde) válida apenas na estadia de 2 horas. Pernoite das 00h00 às 06h00 vale R$ 90,00 em todas as categorias.
      </div>

      <footer class="mt-7 flex flex-col sm:flex-row gap-3">
        <a
          href={whatsappLink(message)}
          target="_blank"
          rel="noopener"
          class="btn btn-whatsapp text-base px-6 py-3.5 flex-1"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Reservar esta suíte pelo WhatsApp
        </a>
        <button type="button" class="btn btn-ghost text-base px-6 py-3.5" data-modal-close>
          Voltar
        </button>
      </footer>

      <p class="mt-4 text-xs text-paper/45 italic text-center">{motel.notice}</p>
    </div>
  </div>
</dialog>
