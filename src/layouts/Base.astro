---
import "../styles/global.css";
import { motel } from "~/data/motel";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = motel.seo.title,
  description = motel.seo.description,
  pathname = "/",
} = Astro.props;

const canonical = new URL(pathname, motel.seo.siteUrl).toString();
const ogImage = new URL(motel.seo.ogImage, motel.seo.siteUrl).toString();

const lodgingLd = {
  "@context": "https://schema.org",
  "@type": ["LodgingBusiness", "Motel"],
  "@id": `${motel.seo.siteUrl}/#business`,
  name: motel.name,
  alternateName: ["Motel Paraíso", "Paraíso Motel São Luís"],
  description: motel.description,
  slogan: motel.seo.slogan,
  url: motel.seo.siteUrl,
  image: [
    ogImage,
    new URL("/media/logo-1280.webp", motel.seo.siteUrl).toString(),
    new URL("/media/hero-poster.webp", motel.seo.siteUrl).toString(),
  ],
  logo: new URL("/media/logo-640.webp", motel.seo.siteUrl).toString(),
  telephone: motel.contact.phone,
  priceRange: "R$ 40 - R$ 90",
  currenciesAccepted: "BRL",
  paymentAccepted: motel.payment.methods.join(", ") + ", " + motel.payment.terminal,
  numberOfRooms: motel.suites.reduce((sum, s) => sum + s.units, 0),
  knowsLanguage: ["pt-BR"],
  knowsAbout: [
    "motel são luís",
    "hospedagem por hora",
    "suítes com hidromassagem",
    "pernoite",
    "motel 24 horas",
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: `${motel.address.street}, ${motel.address.number}`,
    addressLocality: motel.address.city,
    addressRegion: motel.address.state,
    addressCountry: motel.address.country,
    postalCode: motel.address.postalCode,
    streetAddressLocality: motel.address.neighborhood,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: motel.geo.lat,
    longitude: motel.geo.lng,
  },
  // Tells search engines we serve customers from the entire municipality
  // and the broader metropolitan region, not just the immediate street.
  areaServed: [
    {
      "@type": "City",
      name: "São Luís",
      sameAs: "https://pt.wikipedia.org/wiki/São_Luís_(Maranhão)",
      containedInPlace: {
        "@type": "AdministrativeArea",
        name: "Maranhão",
        sameAs: "https://pt.wikipedia.org/wiki/Maranhão",
      },
    },
    { "@type": "City", name: "São José de Ribamar" },
    { "@type": "City", name: "Paço do Lumiar" },
    { "@type": "City", name: "Raposa" },
  ],
  serviceArea: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: motel.geo.lat,
      longitude: motel.geo.lng,
    },
    geoRadius: "30000", // 30 km — covers the Grande São Luís
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
  sameAs: [motel.contact.instagramUrl],
  amenityFeature: [
    { "@type": "LocationFeatureSpecification", name: "Aberto 24 horas", value: true },
    { "@type": "LocationFeatureSpecification", name: "Estacionamento privativo", value: true },
    { "@type": "LocationFeatureSpecification", name: "Hidromassagem (suítes Super Luxo)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Pole dance (suíte Super Luxo 7)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Espelho no teto (Luxo e Super Luxo)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Sofá erótico (Super Luxo)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Cadeira erótica (Luxo)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Ar condicionado", value: true },
    { "@type": "LocationFeatureSpecification", name: "TV", value: true },
    { "@type": "LocationFeatureSpecification", name: "Frigobar", value: true },
    { "@type": "LocationFeatureSpecification", name: "Cardápio no quarto", value: true },
    { "@type": "LocationFeatureSpecification", name: "Privacidade total", value: true },
  ],
  additionalProperty: [
    { "@type": "PropertyValue", name: "Pagamento via PIX", value: "Sim" },
    { "@type": "PropertyValue", name: "Pernoite", value: "00h00 às 06h00 — R$ 90,00" },
    { "@type": "PropertyValue", name: "Estadia mínima", value: "2 horas — R$ 40,00" },
  ],
  hasMap: motel.maps.shareUrl,
  potentialAction: {
    "@type": "ReserveAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `https://wa.me/${motel.contact.whatsapp}`,
      actionPlatform: ["http://schema.org/MobileWebPlatform", "http://schema.org/DesktopWebPlatform"],
    },
    result: { "@type": "LodgingReservation", name: "Reserva pelo WhatsApp" },
  },
};

// FAQPage schema — eligible for rich snippets in Google SERPs.
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${motel.seo.siteUrl}/#faq`,
  mainEntity: motel.faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

// WebSite schema — strengthens brand recognition and enables sitelinks.
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${motel.seo.siteUrl}/#website`,
  url: motel.seo.siteUrl,
  name: motel.name,
  inLanguage: "pt-BR",
  publisher: { "@id": `${motel.seo.siteUrl}/#business` },
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={motel.seo.keywords.join(", ")} />
    <meta name="author" content={motel.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Locale & geo -->
    <meta name="language" content="Portuguese" />
    <meta name="geo.region" content={motel.geo.region} />
    <meta name="geo.placename" content={motel.geo.placename} />
    <meta name="geo.position" content={`${motel.geo.lat};${motel.geo.lng}`} />
    <meta name="ICBM" content={motel.geo.icbm} />

    <!-- Open Graph -->
    <meta property="og:type" content="business.business" />
    <meta property="og:site_name" content={motel.name} />
    <meta property="og:locale" content={motel.seo.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Logo do ${motel.name}`} />
    <!-- Place metadata for richer Facebook/LinkedIn cards -->
    <meta property="business:contact_data:street_address" content={`${motel.address.street}, ${motel.address.number}`} />
    <meta property="business:contact_data:locality" content={motel.address.city} />
    <meta property="business:contact_data:region" content={motel.address.stateName} />
    <meta property="business:contact_data:postal_code" content={motel.address.postalCode} />
    <meta property="business:contact_data:country_name" content="Brasil" />
    <meta property="business:contact_data:phone_number" content={motel.contact.phone} />
    <meta property="business:contact_data:website" content={motel.seo.siteUrl} />
    <meta property="place:location:latitude" content={String(motel.geo.lat)} />
    <meta property="place:location:longitude" content={String(motel.geo.lng)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Theme & PWA -->
    <meta name="theme-color" content={motel.seo.themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={motel.name} />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://maps.google.com" />
    <link rel="preload" href="/media/hero-poster.webp" as="image" type="image/webp" />
    <link rel="preload" href="/media/logo-640.webp" as="image" type="image/webp" />

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD: LodgingBusiness/Motel + WebSite + FAQPage. Three blocks
         help Google build a richer Knowledge Graph entry. -->
    <script type="application/ld+json" set:html={JSON.stringify(lodgingLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </head>

  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-paper focus:text-cinema focus:px-4 focus:py-2 focus:rounded-full focus:font-semibold">
      Pular para o conteúdo
    </a>
    <slot />

    <script>
      // Lightweight scroll-reveal — fires *before* the element enters the
      // viewport so the animation completes by the time the user actually
      // sees it. On reduced-motion or no IO, reveal everything immediately.
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("in"));
      } else {
        // Reveal anything already on screen instantly to avoid initial flash.
        els.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("in");
          }
        });

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0, rootMargin: "0px 0px 35% 0px" }
        );
        els.forEach((el) => {
          if (!el.classList.contains("in")) io.observe(el);
        });
      }
    </script>
  </body>
</html>
